{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/v1/:path*", "destination": "https://cloudrun-api-production.up.railway.app/v1/:path*" },
    { "source": "/uploads/:path*", "destination": "https://cloudrun-api-production.up.railway.app/uploads/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
